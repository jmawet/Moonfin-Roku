import "pkg:/source/utils/config.bs"
import "pkg:/source/utils/parsedUrl.bs"

function isNodeEvent(msg, field as string) as boolean
    return type(msg) = "roSGNodeEvent" and msg.getField() = field
end function

function getMsgPicker(msg, subnode = "" as string) as object
    node = msg.getRoSGNode()
    ' Subnode allows for handling alias messages
    if subnode <> ""
        node = node.findNode(subnode)
    end if
    coords = node.rowItemSelected
    target = node.content.getChild(coords[0]).getChild(coords[1])
    return target
end function

function getButton(msg, subnode = "buttons" as string) as object
    buttons = msg.getRoSGNode().findNode(subnode)
    if buttons = invalid then return invalid
    active_button = buttons.focusedChild
    return active_button
end function

function leftPad(base as string, fill as string, length as integer) as string
    while len(base) < length
        base = fill + base
    end while
    return base
end function

function ticksToHuman(ticks as longinteger) as string
    totalSeconds = int(ticks / 10000000)
    hours = stri(int(totalSeconds / 3600)).trim()
    minutes = stri(int((totalSeconds - (val(hours) * 3600)) / 60)).trim()
    seconds = stri(totalSeconds - (val(hours) * 3600) - (val(minutes) * 60)).trim()
    if val(hours) > 0 and val(minutes) < 10 then minutes = "0" + minutes
    if val(seconds) < 10 then seconds = "0" + seconds
    r = ""
    if val(hours) > 0 then r = hours + ":"
    r = r + minutes + ":" + seconds
    return r
end function

function ticksToAudioGuide(ticks as longinteger) as string
    totalSeconds = int(ticks / 10000000)
    hours = stri(int(totalSeconds / 3600)).trim()
    minutes = stri(int((totalSeconds - (val(hours) * 3600)) / 60)).trim()
    seconds = stri(totalSeconds - (val(hours) * 3600) - (val(minutes) * 60)).trim()

    if val(hours) > 0 and val(minutes) < 10 then minutes = "0" + minutes
    if val(seconds) < 10 then seconds = "0" + seconds

    r = ""
    if val(hours) > 0 then r = hours + " hours, "
    r = `${r} ${minutes} minutes, ${seconds} seconds`
    return r
end function

function secondsToHuman(totalSeconds as integer, addLeadingMinuteZero as boolean) as string
    humanTime = ""
    hours = stri(int(totalSeconds / 3600)).trim()
    minutes = stri(int((totalSeconds - (val(hours) * 3600)) / 60)).trim()
    seconds = stri(totalSeconds - (val(hours) * 3600) - (val(minutes) * 60)).trim()

    if val(hours) > 0 or addLeadingMinuteZero
        if val(minutes) < 10
            minutes = "0" + minutes
        end if
    end if

    if val(seconds) < 10
        seconds = "0" + seconds
    end if

    if val(hours) > 0
        hours = hours + ":"
    else
        hours = ""
    end if

    humanTime = hours + minutes + ":" + seconds

    return humanTime
end function

' Format time as 12 or 24 hour format based on system clock setting
function formatTime(time) as string
    hours = time.getHours()
    minHourDigits = 1
    if m.global.device.clockFormat = "12h"
        meridian = "AM"
        if hours = 0
            hours = 12
            meridian = "AM"
        else if hours = 12
            hours = 12
            meridian = "PM"
        else if hours > 12
            hours = hours - 12
            meridian = "PM"
        end if
    else
        ' For 24hr Clock, no meridian and pad hours to 2 digits
        minHourDigits = 2
        meridian = ""
    end if

    return Substitute("{0}:{1} {2}", leftPad(stri(hours).trim(), "0", minHourDigits), leftPad(stri(time.getMinutes()).trim(), "0", 2), meridian)

end function

function div_ceiling(a as integer, b as integer) as integer
    if a < b then return 1
    if int(a / b) = a / b
        return a / b
    end if
    return a / b + 1
end function

'Returns the item selected or -1 on backpress or other unhandled closure of dialog.
function get_dialog_result(dialog, port)
    while dialog <> invalid
        msg = wait(0, port)
        if isNodeEvent(msg, "backPressed")
            return -1
        else if isNodeEvent(msg, "itemSelected")
            return dialog.findNode("optionList").itemSelected
        end if
    end while
    'Dialog has closed outside of this loop, return -1 for failure
    return -1
end function

function lastFocusedChild(obj as object) as object
    if isValid(obj)
        child = obj
        for i = 0 to obj.getChildCount()
            if isValid(obj.focusedChild)
                child = child.focusedChild
            end if
        end for
        return child
    else
        return invalid
    end if
end function

function show_dialog(message as string, options = [], defaultSelection = 0) as integer
    lastFocus = lastFocusedChild(m.scene)

    dialog = createObject("roSGNode", "JFMessageDialog")
    if options.count() then dialog.options = options
    if message.len() > 0
        reg = CreateObject("roFontRegistry")
        font = reg.GetDefaultFont()
        dialog.fontHeight = font.GetOneLineHeight()
        dialog.fontWidth = font.GetOneLineWidth(message, 999999999)
        dialog.message = message
    end if

    if defaultSelection > 0
        dialog.findNode("optionList").jumpToItem = defaultSelection
    end if

    dialog.visible = true
    m.scene.appendChild(dialog)
    dialog.setFocus(true)
    group = m.global.sceneManager.callFunc("getActiveScene")
    if isValid(group)
        group.lastFocus = dialog.findNode("optionList")
    end if

    port = CreateObject("roMessagePort")
    dialog.observeField("backPressed", port)
    dialog.findNode("optionList").observeField("itemSelected", port)

    result = get_dialog_result(dialog, port)

    m.scene.removeChildIndex(m.scene.getChildCount() - 1)
    lastFocus.setFocus(true)
    group = m.global.sceneManager.callFunc("getActiveScene")
    if isValid(group)
        group.lastFocus = lastFocus
    end if

    return result
end function

' Updates button visual state for detail screens (Movies, TV Shows, Episodes)
' @param buttonGroups - Array of button group nodes
' @param buttonIndex - Index of the button to highlight
' @param itemIsFavorited - Boolean or invalid indicating if item is favorited
' @param itemContent - Optional item content node for fallback favorite check
' @param unfocusedLabelColor - Optional color for unfocused labels (default: "#CCCCCC")
sub updateDetailButtonVisualState(buttonGroups as object, buttonIndex as integer, itemIsFavorited as dynamic, itemContent = invalid as dynamic, unfocusedLabelColor = "#CCCCCC" as string)
    for i = 0 to buttonGroups.count() - 1
        btnGroup = buttonGroups[i]
        bgRect = btnGroup.findNode(btnGroup.id + "Background")
        icon = btnGroup.findNode(btnGroup.id + "Icon")
        label = btnGroup.findNode(btnGroup.id + "Text")

        isFavoriteButton = (btnGroup.id = "favoriteButton")
        isFavorited = false
        if isFavoriteButton
            if isValid(itemIsFavorited)
                isFavorited = itemIsFavorited
            else if isValid(itemContent) and isChainValid(itemContent, "json.UserData.IsFavorite")
                isFavorited = itemContent.json.UserData.IsFavorite
            end if
        end if

        if i = buttonIndex
            ' This button is focused - show white background and change icon to grey
            if bgRect <> invalid then bgRect.opacity = 1
            if icon <> invalid
                ' Keep favorite icon red if item is favorited, otherwise grey
                if isFavoriteButton and isFavorited
                    icon.blendColor = "#FF0000FF"
                else
                    icon.blendColor = "#666666FF"
                end if
            end if
            if label <> invalid and label.hasField("color") then label.color = "#FFFFFF"
        else
            ' This button is not focused - hide background and reset icon color
            if bgRect <> invalid then bgRect.opacity = 0
            if icon <> invalid
                ' Keep favorite icon red if item is favorited, otherwise white
                if isFavoriteButton and isFavorited
                    icon.blendColor = "#FF0000FF"
                else
                    icon.blendColor = "#FFFFFFFF"
                end if
            end if
            if label <> invalid and label.hasField("color") then label.color = unfocusedLabelColor
        end if
    end for
end sub

function message_dialog(message = "" as string)
    return show_dialog(message, ["OK"])
end function

function option_dialog(options, message = "", defaultSelection = 0) as integer
    return show_dialog(message, options, defaultSelection)
end function

function capitalize(input as string) as string
    return UCase(input.left(1)) + input.mid(1)
end function

' take an incomplete url string and use it to make educated guesses about
' the complete url. then tests these guesses to see if it can find a jf server
' returns the url of the server it found, or an empty string
function inferServerUrl(url as string) as string
    ' if this server is already stored, just use the value directly
    ' the server had to get resolved in the first place to get into the registry
    saved = get_setting("saved_servers")
    if isValid(saved)
        savedServers = ParseJson(saved)
        if isValid(savedServers.lookup(url)) then return url
    end if

    port = CreateObject("roMessagePort")
    hosts = CreateObject("roAssociativeArray")
    reqs = []
    candidates = urlCandidates(url)
    for each endpoint in candidates
        req = CreateObject("roUrlTransfer")
        reqs.push(req) ' keep in scope outside of loop, else -10001
        finalUrl = `${endpoint.proto}://${endpoint.host}${endpoint.port = "" ? "" : `:${endpoint.port}`}${endpoint.path}`
        req.seturl(`${finalUrl}/system/info/public${endpoint.query = "" ? "" : `?${endpoint.query}`}`)
        req.setMessagePort(port)
        hosts.addreplace(req.getidentity().ToStr(), `${finalUrl}${endpoint.query = "" ? "" : `?${endpoint.query}`}`)
        if isStringEqual(endpoint.proto, "https")
            req.setCertificatesFile("common:/certs/ca-bundle.crt")
        end if
        req.AsyncGetToString()
    end for
    handled = 0
    timeout = CreateObject("roTimespan")
    if hosts.count() > 0
        while timeout.totalseconds() < 15
            resp = wait(0, port)
            if type(resp) = "roUrlEvent"
                ' TODO
                ' if response code is a 300 redirect then we should return the redirect url
                ' Make sure this happens or make it happen
                if resp.GetResponseCode() = 200 and isJellyfinServer(resp.GetString())
                    selectedUrl = hosts.lookup(resp.GetSourceIdentity().ToStr())
                    return selectedUrl
                end if
            end if
            handled += 1
            if handled = reqs.count()
                return ""
            end if
        end while
    end if
    return ""
end function

function isString(input as dynamic) as boolean
    if isStringEqual(type(input), "roString") then return true
    if isStringEqual(type(input), "String") then return true
    return false
end function

' this is the "educated guess" logic for inferServerUrl that generates a list of complete url's as candidates
' for the tests in inferServerUrl. takes an incomplete url as an arg and returns a list of extrapolated
' full urls. returned urls are all ParsedUrls.
function urlCandidates(input as string)
    url = ParsedUrl(input)
    ' if the parsed url is invalid then the string is not a valid url
    if not isValid(url) then return []
    supportedProtos = ["http", "https"]
    protoCandidates = isValidAndNotEmpty(url.proto) ? [url.proto] : supportedProtos ' if no proto was declared, try all supported
    urlPort = isValidAndNotEmpty(url.port) ? `:${url.port}` : ""
    urlQuery = isValidAndNotEmpty(url.query) ? `?${url.query}` : ""
    finalCandidates = []
    for each proto in protoCandidates:
        finalCandidates.push(ParsedUrl(`${proto}://${url.host}${urlPort}${url.path}${urlQuery}`))
        if not isValidAndNotEmpty(url.port) ' if the port isn't defined, use default jellyfin and proto ports
            ' jellyfin defaults
            if isStringEqual(proto, "https")
                finalCandidates.push(ParsedUrl(`${proto}://${url.host}:8920${url.path}${urlQuery}`))
            else if isStringEqual(proto, "http")
                finalCandidates.push(ParsedUrl(`${proto}://${url.host}:8096${url.path}${urlQuery}`))
            end if
        end if
    end for
    return finalCandidates
end function

sub setFieldTextValue(field, value)
    setFieldText(field, value)
end sub

sub setFieldText(field, value)
    node = m.top.findNode(field)
    if node = invalid or value = invalid then return

    if type(value) = "roInt" or type(value) = "Integer"
        value = str(value).trim()
    else if type(value) = "roFloat" or type(value) = "Float"
        value = str(value).trim()
    else if type(value) <> "roString" and type(value) <> "String"
        value = ""
    end if

    node.text = value
end sub

' Returns whether or not passed value is valid
function isValid(input as dynamic) as boolean
    return input <> invalid
end function

' Returns whether or not passed string values are equal
function isStringEqual(input1, input2) as boolean
    if not isAllValid([input1, input2]) then return false
    if type(input1) <> "roString" and type(input1) <> "String" then return false
    if type(input2) <> "roString" and type(input2) <> "String" then return false

    return LCase(input1) = LCase(input2)
end function

' Returns whether or not all items in passed array are valid
function isAllValid(input as object) as boolean
    for each item in input
        if not isValid(item) then return false
    end for
    return true
end function

' isChainValid: Returns whether or not all the properties in the passed property chain are valid.
' Stops evaluating at first found false value
'
' @param {dynamic} root - high-level object to test property chain against
' @param {string} propertyPath - chain of properties under root object to test
' @return {boolean} indicating if all properties in chain are valid
function isChainValid(root as dynamic, propertyPath as string) as boolean
    rootPath = root
    properties = propertyPath.Split(".")

    if not isValid(rootPath) then return false

    ' Root path is valid, and no properties were passed. Return state of root
    if properties.count() = 0 then return true
    if properties[0] = "" then return true

    rootPath = rootPath.LookupCI(properties[0])

    if not isValid(rootPath) then return false

    properties.shift()

    if properties.count() <> 0
        nextPath = properties.join(".")
        return isChainValid(rootPath, nextPath)
    end if

    return true
end function

' chainLookupReturn: Loops through passed chain of properties and returns final property chain if chain is valid
' Returns passed default if the chain of properties is invalid
'
' @param {dynamic} root - high-level object to test property chain against
' @param {string} propertyPath - chain of properties under root object to test
' @param {dynamic} default - value to return if chain of properties is invalid
' @return {dynamic} value of final chain of properties
function chainLookupReturn(root as dynamic, propertyPath as string, default as dynamic) as dynamic
    rootPath = root

    regex = CreateObject("roRegex", "[^\.`]+|`[^`]+`", "")
    properties = regex.MatchAll(propertyPath)

    if not isValid(rootPath) then return default

    ' Root path is valid, and no properties were passed. Return state of root
    if properties.count() = 0 then return rootPath
    if properties[0].count() = 0 then return rootPath
    if properties[0][0] = "" then return rootPath

    rootPath = rootPath.LookupCI(properties[0][0].Replace("`", ""))

    if not isValid(rootPath) then return default

    propertyLength = Len(properties[0][0])

    properties.shift()

    if properties.count() <> 0
        nextPath = propertyPath.Mid(propertyLength + 1)
        return chainLookupReturn(rootPath, nextPath, default)
    end if

    return rootPath
end function

' Returns true when the modern home rows style is selected.
function isModernHomeRows() as boolean
    return isStringEqual(chainLookupReturn(m.global.session, "user.settings.`ui.home.rowsStyle`", "modern"), "modern")
end function

' chainLookup: Returns value from property chain using case insensitive lookups
'
' @param {dynamic} root - high-level object to test property chain against
' @param {string} propertyPath - chain of properties under root object to test
' @return {dynamic} value of requested item
function chainLookup(root as dynamic, propertyPath as string) as dynamic
    rootPath = root
    properties = propertyPath.Split(".")

    if not isValid(rootPath) then return rootPath

    ' Root path is valid, and no properties were passed. Return root
    if properties.count() = 0 then return rootPath
    if properties[0] = "" then return rootPath

    rootPath = rootPath.LookupCI(properties[0])
    if not isValid(rootPath) then return invalid

    properties.shift()

    if properties.count() = 0 then return rootPath

    nextPath = properties.join(".")
    return chainLookup(rootPath, nextPath)
end function

' Returns whether or not passed value is valid and not empty
' Accepts a string, or any countable type (arrays and lists)
function isValidAndNotEmpty(input as dynamic) as boolean
    if not isValid(input) then return false
    ' Use roAssociativeArray instead of list so we get access to the doesExist() method
    countableTypes = { "array": 1, "list": 1, "roarray": 1, "roassociativearray": 1, "rolist": 1 }
    inputType = LCase(type(input))
    if inputType = "string" or inputType = "rostring"
        trimmedInput = input.trim()
        return trimmedInput <> ""
    else if inputType = "rosgnode"
        inputId = input.id
        return inputId <> invalid
    else if countableTypes.doesExist(inputType)
        return input.count() > 0
    else
        return false
    end if
end function

' Returns true if the string is a loopback, such as 'localhost' or '127.0.0.1'
function isLocalhost(url as string) as boolean
    ' https://stackoverflow.com/questions/8426171/what-regex-will-match-all-loopback-addresses
    rgx = CreateObject("roRegex", "^localhost$|^127(?:\.[0-9]+){0,2}\.[0-9]+$|^(?:0*\:)*?:?0*1$", "i")
    return rgx.isMatch(url)
end function

' Rounds number to nearest integer
function roundNumber(f as float) as integer
    ' BrightScript only has a "floor" round
    ' This compares floor to floor + 1 to find which is closer
    m = int(f)
    n = m + 1
    x = abs(f - m)
    y = abs(f - n)
    if y > x
        return m
    else
        return n
    end if
end function

' Converts ticks to minutes
function getMinutes(ticks) as integer
    ' A tick is .1ms, so 1/10,000,000 for ticks to seconds,
    ' then 1/60 for seconds to minutes... 1/600,000,000
    return roundNumber(ticks / 600000000.0)
end function

' Converts ticks to total runtime in minutes
function getRuntimeFromTicks(ticks) as integer
    ' A tick is .1ms, so 1/10,000,000 for ticks to seconds,
    ' then 1/60 for seconds to minutes... 1/600,000,000
    return roundNumber(ticks / 600000000.0)
end function

' Formats runtime ticks as human-readable string (e.g., "2h 15m")
function getFormattedRuntime(ticks) as string
    if not isValid(ticks) then return ""

    totalMinutes = roundNumber(ticks / 600000000.0)
    hours = int(totalMinutes / 60)
    minutes = totalMinutes mod 60

    if hours > 0
        if minutes > 0
            return stri(hours).trim() + "h " + stri(minutes).trim() + "m"
        else
            return stri(hours).trim() + "h"
        end if
    else
        return stri(minutes).trim() + "m"
    end if
end function

' Calculates end time by adding runtime ticks to current time
function getEndTimeFromTicks(ticks) as string
    date = CreateObject("roDateTime")
    duration_s = int(ticks / 10000000.0)
    date.fromSeconds(date.asSeconds() + duration_s)
    date.toLocalTime()
    return formatTime(date)
end function

' Get the user's preferred backdrop blur amount
' Returns an integer blur value (0-20), default is 10
' This value is used in ImageURL params to control Jellyfin's server-side blur processing
'
' Get backdrop blur amount for detail screens (movies, TV shows, episodes)
' @return {integer} Blur amount from user settings, or 10 if not set
function getBackdropBlurAmount() as integer
    if not isValid(m.global) or not isValid(m.global.session) then return 10
    if not isValid(m.global.session.user) or not isValid(m.global.session.user.settings) then return 10

    blurSetting = m.global.session.user.settings["ui.backdrop.detailBlurAmount"]
    if isValid(blurSetting)
        blurValue = val(blurSetting)
        if blurValue >= 0 and blurValue <= 20
            return blurValue
        end if
    end if

    return 10 ' Default blur amount
end function

'
' Get backdrop blur amount for home and discovery screens (home, genres, favorites)
' @return {integer} Blur amount from user settings, or 10 if not set
function getHomeBackdropBlurAmount() as integer
    if not isValid(m.global) or not isValid(m.global.session) then return 10
    if not isValid(m.global.session.user) or not isValid(m.global.session.user.settings) then return 10

    blurSetting = m.global.session.user.settings["ui.backdrop.homeBlurAmount"]
    if isValid(blurSetting)
        blurValue = val(blurSetting)
        if blurValue >= 0 and blurValue <= 20
            return blurValue
        end if
    end if

    return 10 ' Default blur amount
end function


' Get whether theme music auto-play is enabled
' Returns a boolean indicating if theme music should play on detail screens
'
' @return {boolean} True if theme music auto-play is enabled, false otherwise
function isThemeMusicEnabled() as boolean
    if not isValid(m.global) or not isValid(m.global.session) then return false
    if not isValid(m.global.session.user) or not isValid(m.global.session.user.settings) then return false

    themeMusicSetting = toBoolean(m.global.session.user.settings["playback.thememusic.enabled"])
    settingType = LCase(Type(themeMusicSetting))

    if settingType = "boolean" or settingType = "roboolean"
        return themeMusicSetting
    end if

    if settingType = "integer" or settingType = "rointeger" or settingType = "int" or settingType = "roint"
        return themeMusicSetting <> 0
    end if

    if settingType = "float" or settingType = "rofloat" or settingType = "double" or settingType = "rodouble"
        return themeMusicSetting <> 0
    end if

    if settingType = "string" or settingType = "rostring"
        normalizedSetting = LCase(themeMusicSetting.trim())
        if normalizedSetting = "1" or normalizedSetting = "yes" or normalizedSetting = "on"
            return true
        end if
        if normalizedSetting = "0" or normalizedSetting = "no" or normalizedSetting = "off"
            return false
        end if
    end if

    return false ' Default is disabled
end function

'
' Returns whether or not the channel version number is higher than the passed version number
function ChannelVersionUpdated(versionToCheck)
    if not isValidAndNotEmpty(versionToCheck) then return true

    version = versionToCheck.split(".")
    if version.Count() < 3
        for i = version.Count() to 3 step 1
            version.push("0")
        end for
    end if

    currentVersion = m.global.app.version.split(".")

    ' Check Major version
    if currentVersion[0].ToInt() > version[0].ToInt() then return true

    ' Check Minor version
    if currentVersion[1].ToInt() > version[1].ToInt() then return true

    ' Check Patch version
    if currentVersion[2].ToInt() > version[2].ToInt() then return true

    return false
end function

function findNodeBySubtype(node, subtype)
    foundNodes = []

    for each child in node.getChildren(-1, 0)
        if lcase(child.subtype()) = "group"
            return findNodeBySubtype(child, subtype)
        end if

        if lcase(child.subtype()) = lcase(subtype)
            foundNodes.push({
                node: child,
                parent: node
            })
        end if
    end for

    return foundNodes
end function

function AssocArrayEqual(Array1 as object, Array2 as object) as boolean
    if not isValid(Array1) or not isValid(Array2)
        return false
    end if

    if not Array1.Count() = Array2.Count()
        return false
    end if

    for each key in Array1
        if not Array2.DoesExist(key)
            return false
        end if

        if Array1[key] <> Array2[key]
            return false
        end if
    end for

    return true
end function

' Search string array for search value. Return if it's found
function inArray(haystack as object, needle as dynamic) as boolean
    valueToFind = needle

    if LCase(type(valueToFind)) <> "rostring" and LCase(type(valueToFind)) <> "string"
        valueToFind = str(needle)
    end if

    for each item in haystack
        if isStringEqual(item, valueToFind) then return true
    end for

    return false
end function

function toString(input) as string
    if LCase(type(input)) = "rostring" or LCase(type(input)) = "string"
        return input
    end if

    return str(input)
end function

'
' startLoadingSpinner: Start a loading spinner and attach it to the main BaseScene.
' Displays an invisible ProgressDialog node by default to disable keypresses while loading.
'
' @param {boolean} [disableRemote=true]
sub startLoadingSpinner(disableRemote = true as boolean)
    if not isValid(m.scene)
        m.scene = m.top.getScene()
    end if

    if isValid(m.scene) and isValid(m.scene.isLoading) and not m.scene.isLoading
        m.scene.disableRemote = disableRemote
        m.scene.isLoading = true
    end if
end sub

sub stopLoadingSpinner()
    if not isValid(m.scene)
        m.scene = m.top.getScene()
    end if

    if isValid(m.scene) and isValid(m.scene.isLoading) and m.scene.isLoading
        m.scene.disableRemote = false
        m.scene.isLoading = false
    end if
end sub

' accepts the raw json string of /system/info/public and returns
' a boolean indicating if ProductName is "Jellyfin Server"
function isJellyfinServer(systemInfo as object) as boolean
    data = ParseJson(systemInfo)
    if isValid(data) and isValid(data.ProductName)
        return LCase(data.ProductName) = m.global.constants.jellyfin_server
    end if
    return false
end function

' Takes an array of data, shuffles the order, then returns the array
' uses the Fisher-Yates shuffling algorithm
function shuffleArray(array as object) as object
    for i = array.count() - 1 to 0 step -1
        j = Rnd(i + 1) - 1
        t = array[i] : array[i] = array[j] : array[j] = t
    end for
    return array
end function

function normalizeSceneGraphColorString(colorSetting as dynamic) as dynamic
    if not isValid(colorSetting) then return invalid

    colorValue = colorSetting.toStr().Trim()
    if colorValue = "" then return invalid

    if colorValue.left(1) = "#"
        colorValue = colorValue.mid(1)
    else if colorValue.left(2) = "0x" or colorValue.left(2) = "0X"
        colorValue = colorValue.mid(2)
    end if

    colorValue = UCase(colorValue)

    if Len(colorValue) = 6
        return "0x" + colorValue + "FF"
    else if Len(colorValue) = 8
        return "0x" + colorValue
    end if

    return invalid
end function

function formatSceneGraphColor(colorSetting as dynamic, defaultColor as string) as string
    normalizedDefault = normalizeSceneGraphColorString(defaultColor)
    if not isValidAndNotEmpty(normalizedDefault)
        normalizedDefault = "0xFFFFFFFF"
    end if

    colorType = Type(colorSetting)
    if colorType <> "String" and colorType <> "roString"
        return normalizedDefault
    end if

    normalizedColor = normalizeSceneGraphColorString(colorSetting)
    if isValidAndNotEmpty(normalizedColor)
        return normalizedColor
    end if

    return normalizedDefault
end function

' Format overlay color setting to a valid SceneGraph color string.
function formatOverlayColor(colorSetting as dynamic, defaultColor as string) as string
    return formatSceneGraphColor(colorSetting, defaultColor)
end function

' convert value to boolean and return value
function toBoolean(value as dynamic) as dynamic
    if value = invalid then return invalid
    valueType = LCase(Type(value))

    if valueType = "boolean" or valueType = "roboolean" then return value
    if valueType <> "string" and valueType <> "rostring" then return value

    normalizedValue = LCase(value.trim())

    if normalizedValue = "true"
        return true
    else if normalizedValue = "false"
        return false
    else
        return value
    end if
end function

' focusAudioMiniPlayer: Moves cursor focus to audio mini player, it it's shown
'
sub focusAudioMiniPlayer()
    scene = m.top.getScene()
    if not isValid(scene) then return

    audioMiniPlayer = scene.findNode("audioMiniPlayer")
    if not isValid(audioMiniPlayer) then return

    if not audioMiniPlayer.callFunc("isVisible") then return

    audioMiniPlayer.callFunc("setSelected", true)
    audioMiniPlayer.setfocus(true)
end sub

' Hides the audio mini player
sub hideAudioMiniPlayer()
    scene = m.top.getScene()
    if not isValid(scene) then return

    audioMiniPlayer = scene.findNode("audioMiniPlayer")
    if not isValid(audioMiniPlayer) then return

    audioMiniPlayer.callFunc("setVisible", false)
end sub

' isSelectedAudioMiniPlayer: Returns bool value indicating if audio mini player is selected
'
function isSelectedAudioMiniPlayer() as boolean
    scene = m.top.getScene()
    if not isValid(scene) then return false

    audioMiniPlayer = scene.findNode("audioMiniPlayer")
    if not isValid(audioMiniPlayer) then return false

    return audioMiniPlayer.callFunc("isSelected")
end function

function findDefaultTrack(streams as dynamic)
    ' Usually the first audio stream, so this should be fast.
    ' But it's not always the first audio stream :-(
    for i = 0 to streams.Count() - 1
        if isStringEqual(streams[i].LookupCI("type"), "audio")
            if chainLookupReturn(streams[i], "IsDefault", false)
                return i
            end if
        end if
    end for

    ' No default?  Return the first one.
    return 1
end function

function getDefaultAudioTrackIndex(streams as dynamic)
    for i = 0 to streams.Count() - 1
        if isStringEqual(streams[i].LookupCI("type"), "audio")
            if chainLookupReturn(streams[i], "IsDefault", false)
                return i
            end if
        end if
    end for

    return -1
end function

' Sets the lastFocus property on the active scene to the provided component
' This is a common pattern when setting focus to ensure the scene manager
' knows where to restore focus when returning to this scene
sub setLastFocus(component as object)
    group = m.global.sceneManager.callFunc("getActiveScene")

    if isValid(group)
        group.lastFocus = component
    end if
end sub

' Gets the active scene and sets its lastFocus property to the provided component
' Returns the active scene group for additional operations if needed
function getActiveSceneAndSetFocus(component as object) as object
    group = m.global.sceneManager.callFunc("getActiveScene")
    group.lastFocus = component
    return group
end function

' Preserves the focus state of the home rows before navigation
' This is used when navigating away from the home screen to ensure
' the user returns to the same position they left from
sub preserveHomeRowsFocus()
    group = m.global.sceneManager.callFunc("getActiveScene")
    group.lastFocus = group.homeRows
end sub

' Initializes and moves a dialog scrollbar based on the focused item
' This is used by RadioDialog and RemoteSubtitleDialog to handle their scrollbar UI
' Parameters:
'   contentArea: The dialog's content area node containing the scrollbar
'   radioOptions: The option list node that contains the selectable items
'   scrollBarColumn: Array containing the scrollbar column node (passed by reference)
'   scrollBarThumb: Array containing the scrollbar thumb node (passed by reference)
'   scrollAmount: The amount to scroll per item (passed by reference)
'   onScrollBarFocusCallback: String name of the callback function to observe focus changes
sub setupAndMoveDialogScrollBar(contentArea as object, radioOptions as object, scrollBarColumn as object, scrollBarThumb as object, scrollAmount as object, onScrollBarFocusCallback as string)
    ' If we haven't found the scrollbar column node yet, try to find it now
    if scrollBarColumn.count() = 0
        scrollBar = findNodeBySubtype(contentArea, "StdDlgScrollbar")
        if scrollBar.count() = 0 or not isValid(scrollBar[0]) or not isValid(scrollBar[0].node)
            return
        end if

        scrollBarColumnNodes = findNodeBySubtype(scrollBar[0].node, "Poster")
        if scrollBarColumnNodes.count() = 0 or not isValid(scrollBarColumnNodes[0]) or not isValid(scrollBarColumnNodes[0].node)
            return
        end if

        scrollBarThumbNodes = findNodeBySubtype(scrollBarColumnNodes[0].node, "Poster")
        if scrollBarThumbNodes.count() = 0 or not isValid(scrollBarThumbNodes[0]) or not isValid(scrollBarThumbNodes[0].node)
            return
        end if

        scrollBarThumbNodes[0].node.blendColor = "#444444"
        ' If the user presses left then right, it's possible for us to lose focus. Ensure focus stays on the option list.
        scrollBar[0].node.observeField("focusedChild", onScrollBarFocusCallback)

        ' Hide the default scrollbar background
        scrollBarColumnNodes[0].node.uri = ""

        ' Create a new scrollbar background so we can move the original nodes freely
        scrollbarBackground = createObject("roSGNode", "Rectangle")
        scrollbarBackground.color = "#101010"
        scrollbarBackground.opacity = "0.3"
        scrollbarBackground.width = "30"
        scrollbarBackground.height = contentArea.clippingRect.height
        scrollbarBackground.translation = [0, 0]
        scrollBar[0].node.insertChild(scrollbarBackground, 0)

        ' Determine the proper scroll amount for the scrollbar
        calculatedScrollAmount = (contentArea.clippingRect.height - int(scrollBarThumbNodes[0].node.height)) / radioOptions.getChildCount()
        calculatedScrollAmount += calculatedScrollAmount / radioOptions.getChildCount()

        ' Update the passed-in arrays/values (BrightScript passes objects by reference)
        scrollBarColumn.clear()
        scrollBarColumn.push(scrollBarColumnNodes[0])
        scrollBarThumb.clear()
        scrollBarThumb.push(scrollBarThumbNodes[0])
        scrollAmount.value = calculatedScrollAmount
    end if

    if not isvalid(radioOptions.focusedChild) or not isvalid(radioOptions.focusedChild.id) then return

    scrollBarColumn[0].node.translation = [0, val(radioOptions.focusedChild.id) * scrollAmount.value]
end sub

' Gets the currently focused item from an ItemGrid component
' Returns the content node of the focused item, or invalid if no item is focused
' Parameters:
'   itemGrid: The ItemGrid component to get the focused item from
function getItemGridFocusedItem(itemGrid as object) as dynamic
    if not isValid(itemGrid) then return invalid
    if not isValid(itemGrid.itemFocused) then return invalid
    if not isValid(itemGrid.content) then return invalid

    return itemGrid.content.getChild(itemGrid.itemFocused)
end function

' Handles section navigation escape key logic for detail screens with sections
' This is a common pattern in screens like ArtistView with multiple scrollable sections
' Parameters:
'   escapeDirection: The direction key that was pressed ("up", "down", "left")
'   sectionNavigation: The navigation menu component
'   sectionScroller: The section scroller component
'   setFocusCallback: Optional function name to call when focusing the navigation (for focus tracking)
sub handleSectionNavigationEscape(escapeDirection as string, sectionNavigation as object, sectionScroller as object)
    if escapeDirection = "up"
        sectionNavigation.selected = sectionScroller.displayedIndex - 1
    else if escapeDirection = "left"
        sectionNavigation.setFocus(true)
        setLastFocus(sectionNavigation)
    else if escapeDirection = "down"
        if sectionScroller.displayedIndex + 1 < sectionNavigation.getChildCount()
            sectionNavigation.selected = sectionScroller.displayedIndex + 1
        end if
    end if
end sub

' Handles the common pattern of stopping a loading operation
' Used in library views when data loading fails or completes
' Parameters:
'   loadingFlag: Reference to the m.Loading or m.loading flag to set to false
sub stopLoadingOperation()
    m.Loading = false
    stopLoadingSpinner()
end sub

' Shared utility for managing background image queuing during transitions
' Sets a new background image URI, or queues it if an animation/load is in progress
'
' Parameters:
'   backgroundUri: The URI of the background image to set
'   newBackdropNode: Reference to the Poster node for the new backdrop
'   swapAnimationNode: Reference to the Animation node for backdrop swapping
'
' Returns: true if URI was set immediately, false if queued (stored in m.queuedBGUri)
'
' Usage:
'   setBackgroundWithQueue(uri, m.newBackdrop, m.swapAnimation)
function setBackgroundWithQueue(backgroundUri as string, newBackdropNode as object, swapAnimationNode as object) as boolean
    animationState = LCase(swapAnimationNode.state)
    loadStatus = LCase(newBackdropNode.loadStatus)

    if animationState <> "stopped" or loadStatus = "loading"
        m.queuedBGUri = backgroundUri
        return false
    end if

    newBackdropNode.uri = backgroundUri
    return true
end function

' Validates nested object properties in a single check
' Useful for checking if an object has deeply nested valid properties
'
' Parameters:
'   obj: The root object to validate
'   prop1: First property name (string) to check on obj
'   prop2: Optional second property name (string) to check on obj.prop1
'
' Returns: true if all specified nested properties are valid
'
' Usage:
'   hasValidProperties(item, "ImageTags", "Primary") - checks item.ImageTags and item.ImageTags.Primary
'   hasValidProperties(item, "UserData", "Played") - checks item.UserData and item.UserData.Played
'   hasValidProperties(item, "json") - checks only item.json
function hasValidProperties(obj as object, prop1 as string, prop2 = invalid as dynamic) as boolean
    if not isValid(obj)
        return false
    end if

    ' Check first level property
    firstLevel = obj[prop1]
    if not isValid(firstLevel)
        return false
    end if

    ' If no second property specified, we're done
    if prop2 = invalid
        return true
    end if

    ' Check second level property
    return isValid(firstLevel[prop2])
end function

' Convenience function for common ImageTags.Primary validation pattern
'
' Parameters:
'   obj: Object with ImageTags property (item, json, etc.)
'
' Returns: true if obj.ImageTags.Primary exists and is valid
'
' Usage:
'   if hasImageTagPrimary(item) then...
function hasImageTagPrimary(obj as object) as boolean
    return hasValidProperties(obj, "ImageTags", "Primary")
end function

' Convenience wrapper for creating SceneGraph nodes
' Reduces boilerplate for common node creation patterns
'
' Parameters:
'   nodeType: String name of the node type to create
'
' Returns: The created roSGNode object
'
' Usage:
'   tmp = createSGNode("HomeData")
'   content = createSGNode("ContentNode")
function createSGNode(nodeType as string) as object
    return CreateObject("roSGNode", nodeType)
end function

' Attempts to focus the navbar/overhang from the current screen.
' This is a helper function to reduce code duplication across screens.
' Typically called when the user presses the UP key from content.
'
' Parameters:
'   componentNode: The current component node (usually m.top)
'
' Returns: True if overhang was found and focused, false otherwise
'
' Usage in onKeyEvent:
'   if key = "up" or key = "Up"
'       return FocusOverhang(m.top)
'   end if
function FocusOverhang(componentNode as object) as boolean
    if not isValid(componentNode) then return false

    scene = componentNode.getScene()
    if not isValid(scene) then return false

    sidebar = scene.findNode("sidebar")
    if isValid(sidebar) and sidebar.visible
        return false
    end if

    nav = scene.findNode("overhang")
    if isValid(nav)
        nav.setFocus(true)
        return true
    end if

    return false
end function

function FocusSidebar(componentNode as object) as boolean
    if not isValid(componentNode) then return false

    scene = componentNode.getScene()
    if not isValid(scene) then return false

    sidebar = scene.findNode("sidebar")
    if isValid(sidebar) and sidebar.visible
        sidebar.setFocus(true)
        return true
    end if

    return false
end function

function getActiveNav(scene as object) as object
    if not isValid(scene) then return invalid

    sidebar = scene.findNode("sidebar")
    if isValid(sidebar) and sidebar.visible
        return sidebar
    end if

    return scene.findNode("overhang")
end function

sub centerButtonRowInContainer(buttonRow as object, buttonCount as integer, buttonWidth = 168 as integer, buttonSpacing = 40 as integer, containerOffset = 0 as integer)
    if buttonRow = invalid or buttonCount = 0 then return

    totalWidth = (buttonCount * buttonWidth) + ((buttonCount - 1) * buttonSpacing)
    screenWidth = 1920
    centerX = ((screenWidth - totalWidth) / 2) - containerOffset

    currentTranslation = buttonRow.translation
    buttonRow.translation = [centerX, currentTranslation[1]]
end sub

function serverVersionMeetsMinimumRequirements(systemVersion as string, targetVersion as roArray) as boolean
    version = systemVersion.split(".")
    if version.Count() < 3
        for i = version.Count() to 3 step 1
            version.push("0")
        end for
    end if

    ' Check Major version
    if targetVersion[0] < version[0].ToInt() then return true
    if targetVersion[0] > version[0].ToInt() then return false

    ' Check Minor version
    if targetVersion[1] < version[1].ToInt() then return true
    if targetVersion[1] > version[1].ToInt() then return false

    ' Check Patch version
    if targetVersion[2] < version[2].ToInt() then return true
    if targetVersion[2] > version[2].ToInt() then return false

    ' Server is the exact version needed
    return true
end function

' Strip HTML tags from a string, decode common HTML entities, and normalize whitespace
function stripHtmlTags(text as string) as string
    if text = "" then return text

    ' Remove HTML tags
    htmlRegex = CreateObject("roRegex", "<[^>]*>", "s")
    result = htmlRegex.ReplaceAll(text, "")

    ' Decode common HTML entities
    result = result.Replace("&amp;", "&")
    result = result.Replace("&lt;", "<")
    result = result.Replace("&gt;", ">")
    result = result.Replace("&quot;", chr(34))
    result = result.Replace("&#39;", "'")
    result = result.Replace("&apos;", "'")
    result = result.Replace("&nbsp;", " ")

    ' Replace <br> variants that may have been missed
    brRegex = CreateObject("roRegex", "<br\s*/?>", "is")
    result = brRegex.ReplaceAll(result, chr(10))

    ' Collapse multiple blank lines to a single one
    blankLineRegex = CreateObject("roRegex", "(\n\s*){3,}", "s")
    result = blankLineRegex.ReplaceAll(result, chr(10) + chr(10))

    return result.trim()
end function
