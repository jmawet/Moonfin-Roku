import "pkg:/source/api/baserequest.bs"
import "pkg:/source/utils/misc.bs"

sub init()
    m.top.functionName = "loadRows"
end sub

sub loadRows()
    m.top.errorMessage = ""
    m.top.rows = []

    sourceFilter = normalizeHomeRowsSource(m.top.source)

    req = targetAPIRequest("/Moonfin/HomeRows/tv")
    if not isValid(req)
        m.top.errorMessage = "Unable to fetch resolved home rows"
        return
    end if

    response = getJson(req)
    rowsPayload = getRowsPayload(response)
    if not isArrayValue(rowsPayload)
        return
    end if

    normalizedRows = []
    rowIndex = 0
    for each row in rowsPayload
        normalized = normalizeRow(row, rowIndex)
        if not isAssociativeArrayValue(normalized)
            rowIndex++
            continue for
        end if

        rowSource = chainLookupReturn(normalized, "source", "")
        if isValidAndNotEmpty(sourceFilter) and rowSource <> sourceFilter
            rowIndex++
            continue for
        end if

        normalizedRows.push(normalized)
        rowIndex++
    end for

    m.top.rows = sortRowsByOrder(normalizedRows)
end sub

function targetAPIRequest(path as string, params = {} as object) as dynamic
    if not isValidAndNotEmpty(m.top.serverUrl)
        return invalid
    end if

    return APIRequestForServer(m.top.serverUrl, m.top.userId, m.top.authToken, path, params)
end function

function getRowsPayload(response as dynamic) as dynamic
    if not isValid(response)
        return []
    end if

    if isArrayValue(response)
        return response
    end if

    if not isAssociativeArrayValue(response)
        return []
    end if

    rows = chainLookupReturn(response, "rows", [])

    if isArrayValue(rows)
        return rows
    end if

    return []
end function

function normalizeRow(row as dynamic, fallbackOrder = 0 as integer) as dynamic
    if not isAssociativeArrayValue(row)
        return invalid
    end if

    rowId = toNormalizedString(chainLookupReturn(row, "id", ""))
    rowTitle = toNormalizedString(chainLookupReturn(row, "title", ""))
    rowSource = normalizeHomeRowsSource(chainLookupReturn(row, "source", ""))

    rowRoute = toNormalizedString(chainLookupReturn(row, "route", ""))
    if not isValidAndNotEmpty(rowId)
        rowId = rowRoute
    end if
    if not isValidAndNotEmpty(rowId)
        rowId = "row-" + fallbackOrder.ToStr()
    end if

    if not isValidAndNotEmpty(rowTitle)
        rowTitle = rowId
    end if

    return {
        id: rowId,
        title: rowTitle,
        source: rowSource,
        kind: LCase(toNormalizedString(chainLookupReturn(row, "kind", ""))),
        enabled: normalizeBoolean(chainLookupReturn(row, "enabled", true), true),
        order: parseIntValue(chainLookupReturn(row, "order", fallbackOrder), fallbackOrder),
        route: rowRoute,
        additionalData: chainLookupReturn(row, "additionalData", invalid)
    }
end function

function sortRowsByOrder(rows as object) as object
    if not isArrayValue(rows)
        return []
    end if

    sortedRows = []
    for each row in rows
        inserted = false
        for i = 0 to sortedRows.Count() - 1
            if parseIntValue(chainLookupReturn(row, "order", i), i) < parseIntValue(chainLookupReturn(sortedRows[i], "order", i), i)
                sortedRows.Insert(i, row)
                inserted = true
                exit for
            end if
        end for

        if not inserted
            sortedRows.push(row)
        end if
    end for

    return sortedRows
end function

function normalizeHomeRowsSource(value as dynamic) as string
    return LCase(toNormalizedString(value))
end function

function normalizeBoolean(value as dynamic, defaultValue = false as boolean) as boolean
    if not isValid(value)
        return defaultValue
    end if

    valueType = type(value)
    if valueType = "Boolean" or valueType = "roBoolean"
        return value
    end if

    if valueType = "String" or valueType = "roString"
        return LCase(value) = "true"
    end if

    return defaultValue
end function

function parseIntValue(value as dynamic, defaultValue = 0 as integer) as integer
    if not isValid(value)
        return defaultValue
    end if

    valueType = type(value)
    if valueType = "Integer" or valueType = "LongInteger" or valueType = "roInteger" or valueType = "roInt"
        return value
    end if

    if valueType = "Float" or valueType = "Double" or valueType = "roFloat" or valueType = "roDouble"
        return Int(value)
    end if

    if valueType = "String" or valueType = "roString"
        return Int(Val(value))
    end if

    return defaultValue
end function

function isArrayValue(value as dynamic) as boolean
    valueType = type(value)
    return valueType = "Array" or valueType = "roArray"
end function

function isAssociativeArrayValue(value as dynamic) as boolean
    valueType = type(value)
    return valueType = "AssociativeArray" or valueType = "roAssociativeArray"
end function

function toNormalizedString(value as dynamic) as string
    if not isValid(value)
        return ""
    end if

    valueType = type(value)
    if valueType = "String" or valueType = "roString"
        return value.Trim()
    end if

    return value.ToStr().Trim()
end function
