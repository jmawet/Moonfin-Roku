function loadSeasons() as object
    results = []

    if not isValid(m.top.itemId) or m.top.itemId = "" then return results

    params = {
        userId: m.global.session.user.id,
        ParentId: m.top.itemId,
        Fields: "Overview,PrimaryImageAspectRatio,ChildCount,MediaSources",
        enableTotalRecordCount: true
    }

    data = api.items.Get(params)

    if not isChainValid(data, "Items") then return results

    for each season in data.Items
        tmp = createSGNode("HomeData")
        tmp.json = {
            id: season.LookupCI("Id"),
            name: season.LookupCI("Name"),
            Type: season.LookupCI("Type"),
            year: season.LookupCI("ProductionYear"),
            overview: season.LookupCI("Overview"),
            ImageTags: season.LookupCI("ImageTags"),
            SeriesImageTags: season.LookupCI("SeriesImageTags"),
            BackdropImageTags: season.LookupCI("BackdropImageTags"),
            ParentBackdropImageTags: season.LookupCI("ParentBackdropImageTags"),
            ParentBackdropItemId: season.LookupCI("ParentBackdropItemId"),
            UserData: season.LookupCI("UserData")
        }

        ' Build poster URL - use lowercase posterUrl to match ExtrasItem expectations
        seasonId = season.LookupCI("Id")
        params = {
            maxWidth: 300,
            quality: 90
        }
        if hasImageTagPrimary(season)
            params.Tag = season.ImageTags.Primary
            tmp.posterUrl = ImageUrl(seasonId, "Primary", params)
        else if hasValidProperties(season, "SeriesImageTags", "Primary")
            params.Tag = season.SeriesImageTags.Primary
            tmp.posterUrl = ImageUrl(seasonId, "Primary", params)
        else
            tmp.posterUrl = ""
        end if

        results.push(tmp)
    end for

    return results
end function

