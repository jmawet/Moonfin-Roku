sub init()
    m.top.itemsToLoad = "libraries"
    m.top.functionName = "loadItems"
end sub

function loadLibraries() as object
    results = []

    data = api.GetUserViews({ "userId": m.global.session.user.id })

    if not isChainValid(data, "items") then return results

    listData = loadMyList()

    if isValidAndNotEmpty(listData)
        data.items.unshift({
            id: listData[0].json.LookupCI("playlistid"),
            name: `My List`,
            Type: ItemType.COLLECTIONFOLDER,
            CollectionType: ItemType.MYLIST
        })
    end if

    for each item in data.LookupCI("items")
        tmp = createSGNode("HomeData")
        tmp.json = {
            id: item.LookupCI("Id"),
            name: item.LookupCI("name"),
            Type: item.LookupCI("Type"),
            CollectionType: item.LookupCI("CollectionType"),
            ImageTags: item.LookupCI("ImageTags"),
            UserData: item.LookupCI("UserData"),
            ParentThumbImageTag: item.LookupCI("ParentThumbImageTag"),
            ParentBackdropImageTags: item.LookupCI("ParentBackdropImageTags"),
            ParentBackdropItemId: item.LookupCI("ParentBackdropItemId"),
            SeriesPrimaryImageTag: item.LookupCI("SeriesPrimaryImageTag"),
            BackdropImageTags: item.LookupCI("BackdropImageTags")
        }
        results.push(tmp)
    end for

    return results
end function

function loadLatestMedia() as object
    results = []

    params = {
        userId: m.global.session.user.id,
        limit: 25,
        parentId: m.top.itemId,
        enableImageTypes: `${ImageType.PRIMARY}, ${ImageType.BACKDROP}, ${ImageType.THUMB}`,
        imageTypeLimit: 1,
        enableTotalRecordCount: false,
        fields: "Genres"
    }

    data = api.items.GetLatest(params)

    if not isValidAndNotEmpty(data) then return results

    for each item in data
        if not isStringEqual(item.Type, ItemType.BOOK)
            tmp = createSGNode("HomeData")

            tmp.json = {
                id: item.LookupCI("Id"),
                name: item.LookupCI("name"),
                Type: item.LookupCI("Type"),
                CollectionType: item.LookupCI("CollectionType"),
                ChannelName: item.LookupCI("ChannelName"),
                ChannelId: item.LookupCI("ChannelId"),
                EpisodeTitle: item.LookupCI("EpisodeTitle"),
                ChildCount: item.LookupCI("ChildCount"),
                EndDate: item.LookupCI("EndDate"),
                OfficialRating: item.LookupCI("OfficialRating"),
                ProductionYear: item.LookupCI("ProductionYear"),
                Album: item.LookupCI("Album"),
                SeriesName: item.LookupCI("SeriesName"),
                SeriesId: item.LookupCI("SeriesId"),
                SeasonId: item.LookupCI("SeasonId"),
                ParentIndexNumber: item.LookupCI("ParentIndexNumber"),
                IndexNumber: item.LookupCI("IndexNumber"),
                IndexNumberEnd: item.LookupCI("IndexNumberEnd"),
                AlbumArtist: item.LookupCI("AlbumArtist"),
                AlbumArtistId: isValidAndNotEmpty(item.AlbumArtists) ? item.AlbumArtists[0].LookupCI("id") : invalid,
                Genre: isValidAndNotEmpty(item.GenreItems) ? item.GenreItems : invalid,
                Status: item.LookupCI("Status"),
                ImageTags: item.LookupCI("ImageTags"),
                UserData: item.LookupCI("UserData"),
                ParentThumbImageTag: item.LookupCI("ParentThumbImageTag"),
                ParentBackdropImageTags: item.LookupCI("ParentBackdropImageTags"),
                ParentBackdropItemId: item.LookupCI("ParentBackdropItemId"),
                SeriesPrimaryImageTag: item.LookupCI("SeriesPrimaryImageTag"),
                BackdropImageTags: item.LookupCI("BackdropImageTags"),
                LibraryId: m.top.itemId
            }
            results.push(tmp)
        end if
    end for

    return results
end function

function loadRecentlyReleased() as object
    results = []

    params = {
        userId: m.global.session.user.id,
        limit: 50,
        parentId: m.top.itemId,
        recursive: true,
        fields: "PrimaryImageAspectRatio,Genres,Overview",
        enableImageTypes: `${ImageType.PRIMARY}, ${ImageType.BACKDROP}, ${ImageType.THUMB}`,
        imageTypeLimit: 1,
        includeItemTypes: `${ItemType.MOVIE}, ${ItemType.SERIES}, ${ItemType.BOOK}, ${ItemType.AUDIOBOOK}, ${ItemType.MUSICALBUM}`,
        sortBy: "PremiereDate,ProductionYear,SortName",
        sortOrder: "Descending",
        enableTotalRecordCount: false
    }

    data = api.items.Get(params)

    if not isValidAndNotEmpty(data) or not isValidAndNotEmpty(data.items) then return results

    for each item in data.items
        tmp = createSGNode("HomeData")

        albumArtistID = invalid

        if isValidAndNotEmpty(item.AlbumArtists)
            albumArtistID = item.AlbumArtists[0].LookupCI("id")
        end if

        tmp.json = {
            id: item.LookupCI("Id"),
            name: item.LookupCI("name"),
            Type: item.LookupCI("Type"),
            CollectionType: item.LookupCI("CollectionType"),
            ChannelName: item.LookupCI("ChannelName"),
            ChannelId: item.LookupCI("ChannelId"),
            EpisodeTitle: item.LookupCI("EpisodeTitle"),
            ChildCount: item.LookupCI("ChildCount"),
            EndDate: item.LookupCI("EndDate"),
            OfficialRating: item.LookupCI("OfficialRating"),
            ProductionYear: item.LookupCI("ProductionYear"),
            PremiereDate: item.LookupCI("PremiereDate"),
            Album: item.LookupCI("Album"),
            SeriesName: item.LookupCI("SeriesName"),
            SeriesId: item.LookupCI("SeriesId"),
            SeasonId: item.LookupCI("SeasonId"),
            ParentIndexNumber: item.LookupCI("ParentIndexNumber"),
            IndexNumber: item.LookupCI("IndexNumber"),
            IndexNumberEnd: item.LookupCI("IndexNumberEnd"),
            AlbumArtist: item.LookupCI("AlbumArtist"),
            AlbumArtistId: albumArtistID,
            Status: item.LookupCI("Status"),
            ImageTags: item.LookupCI("ImageTags"),
            UserData: item.LookupCI("UserData"),
            ParentThumbImageTag: item.LookupCI("ParentThumbImageTag"),
            ParentBackdropImageTags: item.LookupCI("ParentBackdropImageTags"),
            ParentBackdropItemId: item.LookupCI("ParentBackdropItemId"),
            SeriesPrimaryImageTag: item.LookupCI("SeriesPrimaryImageTag"),
            BackdropImageTags: item.LookupCI("BackdropImageTags")
        }
        results.push(tmp)
    end for

    return results
end function

' Wraps a Jellyfin item in a HomeData node using the standard home row fields.
function makeHomeItem(item as object) as object
    tmp = createSGNode("HomeData")
    tmp.json = {
        Id: item.LookupCI("Id"),
        name: item.LookupCI("name"),
        Type: item.LookupCI("Type"),
        CollectionType: item.LookupCI("CollectionType"),
        OfficialRating: item.LookupCI("OfficialRating"),
        ProductionYear: item.LookupCI("ProductionYear"),
        PremiereDate: item.LookupCI("PremiereDate"),
        SeriesName: item.LookupCI("SeriesName"),
        SeriesId: item.LookupCI("SeriesId"),
        SeasonId: item.LookupCI("SeasonId"),
        ParentIndexNumber: item.LookupCI("ParentIndexNumber"),
        IndexNumber: item.LookupCI("IndexNumber"),
        IndexNumberEnd: item.LookupCI("IndexNumberEnd"),
        ImageTags: item.LookupCI("ImageTags"),
        UserData: item.LookupCI("UserData"),
        ParentThumbItemId: item.LookupCI("ParentThumbItemId"),
        ParentThumbImageTag: item.LookupCI("ParentThumbImageTag"),
        ParentBackdropImageTags: item.LookupCI("ParentBackdropImageTags"),
        ParentBackdropItemId: item.LookupCI("ParentBackdropItemId"),
        SeriesPrimaryImageTag: item.LookupCI("SeriesPrimaryImageTag"),
        BackdropImageTags: item.LookupCI("BackdropImageTags")
    }
    return tmp
end function

function getBoolSetting(settings as object, key as string, defaultValue as boolean) as boolean
    if not isValid(settings) then return defaultValue
    value = settings[key]
    if not isValid(value) then return defaultValue
    if type(value) = "String" or type(value) = "roString" then return LCase(value) = "true"
    return value = true
end function

function getStringSetting(settings as object, key as string, defaultValue as string) as string
    if not isValid(settings) then return defaultValue
    value = settings[key]
    if isValidAndNotEmpty(value) then return value.toStr()
    return defaultValue
end function

function joinArray(items as object, separator as string) as string
    result = ""
    first = true
    for each value in items
        if not isValid(value) then continue for
        if first
            result = value.toStr()
            first = false
        else
            result = result + separator + value.toStr()
        end if
    end for
    return result
end function

function isItemPlayed(item as object) as boolean
    userData = item.LookupCI("UserData")
    if isValid(userData) then return userData.Played = true
    return false
end function

function seedItemTypes(sourceItem as string, sourceType as string) as string
    contentType = LCase(sourceType)
    if LCase(sourceItem) = "recentlywatched"
        if contentType = "movies" then return "Movie"
        if contentType = "shows" then return "Episode"
        return "Movie,Episode"
    end if
    if contentType = "movies" then return "Movie"
    if contentType = "shows" then return "Series"
    return "Movie,Series"
end function

function candidateTypesFor(sourceType as string) as string
    contentType = LCase(sourceType)
    if contentType = "movies" then return "Movie"
    if contentType = "shows" then return "Series"
    return "Movie,Series"
end function

' Fetches parent series for any watched episodes so a seed represents a show.
function fetchSeriesForEpisodes(rawItems as object) as object
    seriesById = {}
    seriesIds = []
    seen = {}

    for each item in rawItems
        if item.LookupCI("Type") = "Episode"
            sId = item.LookupCI("SeriesId")
            if isValidAndNotEmpty(sId) and not seen.DoesExist(sId)
                seen[sId] = true
                seriesIds.Push(sId)
            end if
        end if
    end for
    if seriesIds.Count() = 0 then return seriesById

    data = api.items.Get({
        UserId: m.global.session.user.id,
        Ids: joinArray(seriesIds, ","),
        fields: "Genres,Tags,People,Studios,ProductionYear,ProviderIds,PremiereDate,ImageTags,OfficialRating,CommunityRating,UserData"
    })
    if not isChainValid(data, "Items") then return seriesById

    for each series in data.Items
        sId = series.LookupCI("Id")
        if isValidAndNotEmpty(sId) then seriesById[sId] = series
    end for
    return seriesById
end function

function loadSinceYouWatchedSeeds(sourceItem as string, sourceType as string) as object
    params = {
        UserId: m.global.session.user.id,
        recursive: true,
        includeItemTypes: seedItemTypes(sourceItem, sourceType),
        limit: 30,
        fields: "Genres,Tags,People,Studios,ProductionYear,SeriesId,UserData,ProviderIds,PremiereDate,ImageTags,OfficialRating,CommunityRating",
        EnableTotalRecordCount: false
    }

    if LCase(sourceItem) = "favorites"
        params.filters = "IsPlayed,IsFavorite"
    else if LCase(sourceItem) = "random"
        params.filters = "IsPlayed"
        params.sortBy = "Random"
    else
        params.filters = "IsPlayed"
        params.sortBy = "DatePlayed"
        params.sortOrder = "Descending"
    end if

    data = api.items.Get(params)
    if not isChainValid(data, "Items") then return []

    if LCase(sourceItem) = "recentlywatched"
        seriesById = fetchSeriesForEpisodes(data.Items)
        return HomeRecommendations.resolveSeedEpisodes(data.Items, seriesById)
    end if

    return data.Items
end function

sub addRecommendationCandidates(candidates as object, data as object)
    if not isChainValid(data, "Items") then return
    for each item in data.Items
        id = item.LookupCI("Id")
        if isValidAndNotEmpty(id) then candidates[id] = item
    end for
end sub

function scoredEntryComesAfter(a as object, b as object) as boolean
    if a.score <> b.score then return a.score < b.score
    return getPremiereDate(a.item) < getPremiereDate(b.item)
end function

function getPremiereDate(item as object) as string
    value = item.LookupCI("PremiereDate")
    if isValidAndNotEmpty(value) then return value.toStr()
    return ""
end function

sub sortScoredCandidates(scored as object)
    total = scored.Count()
    for i = 1 to total - 1
        current = scored[i]
        j = i - 1
        while j >= 0 and scoredEntryComesAfter(scored[j], current)
            scored[j + 1] = scored[j]
            j = j - 1
        end while
        scored[j + 1] = current
    end for
end sub

' Local recommender. Pulls candidates sharing the seeds genres, tags, or people,
' scores them, and returns the best matches.
function loadSinceYouWatchedLocal(seed as object, sourceType as string, includeWatched as boolean) as object
    ctx = HomeRecommendations.buildContext(seed)
    candidateTypes = candidateTypesFor(sourceType)
    baseId = seed.LookupCI("Id")
    if not isValid(baseId) then baseId = ""

    candidateFields = "Genres,Tags,People,UserData,OfficialRating,ProductionYear,CommunityRating,Studios,PremiereDate,ImageTags,SeriesPrimaryImageTag,BackdropImageTags"
    candidates = {}

    if ctx.genres.Count() > 0
        addRecommendationCandidates(candidates, api.items.Get({
            UserId: m.global.session.user.id,
            includeItemTypes: candidateTypes,
            genres: joinArray(ctx.genres, "|"),
            recursive: true,
            limit: 40,
            fields: candidateFields,
            EnableTotalRecordCount: false
        }))
    end if

    if ctx.tags.Count() > 0
        addRecommendationCandidates(candidates, api.items.Get({
            UserId: m.global.session.user.id,
            includeItemTypes: candidateTypes,
            tags: joinArray(ctx.tags, "|"),
            recursive: true,
            limit: 40,
            fields: candidateFields,
            EnableTotalRecordCount: false
        }))
    end if

    personIds = []
    for each pid in ctx.directorIds : personIds.Push(pid) : end for
    for each pid in ctx.writerIds : personIds.Push(pid) : end for
    actorCount = 0
    for each pid in ctx.actorIds
        if actorCount >= 10 then exit for
        personIds.Push(pid)
        actorCount = actorCount + 1
    end for
    if personIds.Count() > 0
        addRecommendationCandidates(candidates, api.items.Get({
            UserId: m.global.session.user.id,
            includeItemTypes: candidateTypes,
            personIds: joinArray(personIds, ","),
            recursive: true,
            limit: 40,
            fields: candidateFields,
            EnableTotalRecordCount: false
        }))
    end if

    scored = []
    for each id in candidates
        candidate = candidates[id]
        if id = baseId then continue for
        if not includeWatched and isItemPlayed(candidate) then continue for
        scored.Push({ item: candidate, score: HomeRecommendations.scoreCandidate(candidate, ctx) })
    end for

    ' Not enough matches, so pull recent titles in the same genres as filler.
    if scored.Count() < 15
        fillerParams = {
            UserId: m.global.session.user.id,
            includeItemTypes: candidateTypes,
            recursive: true,
            limit: 30,
            sortBy: "ProductionYear,SortName",
            sortOrder: "Descending",
            fields: candidateFields,
            EnableTotalRecordCount: false
        }
        if ctx.genres.Count() > 0 then fillerParams.genres = joinArray(ctx.genres, "|")
        fillerData = api.items.Get(fillerParams)
        if isChainValid(fillerData, "Items")
            for each fillerItem in fillerData.Items
                fillerId = fillerItem.LookupCI("Id")
                if not isValidAndNotEmpty(fillerId) or candidates.DoesExist(fillerId) or fillerId = baseId then continue for
                if not includeWatched and isItemPlayed(fillerItem) then continue for
                candidates[fillerId] = fillerItem
                scored.Push({ item: fillerItem, score: HomeRecommendations.scoreCandidate(fillerItem, ctx) })
                if scored.Count() >= 30 then exit for
            end for
        end if
    end if

    sortScoredCandidates(scored)

    results = []
    count = 0
    for each entry in scored
        if count >= 15 then exit for
        results.Push(makeHomeItem(entry.item))
        count = count + 1
    end for
    return results
end function

function getSeedTmdbId(seed as object) as string
    providerIds = seed.LookupCI("ProviderIds")
    if isValid(providerIds)
        raw = providerIds.LookupCI("Tmdb")
        if isValid(raw) then return raw.toStr()
    end if

    seedId = seed.LookupCI("Id")
    if not isValidAndNotEmpty(seedId) then return ""

    detail = api.items.GetByID(seedId, { UserId: m.global.session.user.id, fields: "ProviderIds" })
    if isValid(detail)
        providerIds = detail.LookupCI("ProviderIds")
        if isValid(providerIds)
            raw = providerIds.LookupCI("Tmdb")
            if isValid(raw) then return raw.toStr()
        end if
    end if
    return ""
end function

' Builds a HomeData node for a recommendation result. The raw item is kept on the
' node so selecting it can open the Seerr detail screen. Results may use TMDB
' snake_case or Seerr camelCase, so both are handled.
function makeSeerrHomeItem(res as object, defaultMediaType as string) as object
    if not isValid(res) then return invalid
    tmdbId = res.LookupCI("id")
    if not isValid(tmdbId) then return invalid

    mediaType = res.LookupCI("mediaType")
    if not isValidAndNotEmpty(mediaType) then mediaType = res.LookupCI("media_type")
    if not isValidAndNotEmpty(mediaType) then mediaType = defaultMediaType

    title = res.LookupCI("title")
    if not isValidAndNotEmpty(title) then title = res.LookupCI("name")
    if not isValidAndNotEmpty(title) then title = "Unknown"

    posterPath = res.LookupCI("posterPath")
    if not isValidAndNotEmpty(posterPath) then posterPath = res.LookupCI("poster_path")

    posterUrl = ""
    if isValidAndNotEmpty(posterPath)
        tmdbUrls = GetTmdbImageBaseUrls()
        posterUrl = tmdbUrls.posterW342 + posterPath
    end if

    ' Keep the raw item for the detail screen and make sure it carries a media type.
    res.mediaType = mediaType

    tmp = createSGNode("HomeData")
    tmp.json = {
        Id: tmdbId.toStr(),
        name: title,
        Type: (mediaType = "tv") ? "Series" : "Movie",
        SeerrTmdbId: tmdbId.toStr(),
        SeerrMediaType: mediaType,
        SeerrPosterURL: posterUrl,
        SeerrItem: res
    }
    return tmp
end function

' Recommendations from TMDB, using the key the plugin syncs to the client.
function fetchTmdbRecommendations(tmdbId as string, mediaType as string) as object
    apiKey = getStringSetting(m.global.session.user.settings, "plugin.tmdb.apiKey", "")
    if apiKey = "" then return []

    url = "https://api.themoviedb.org/3/" + mediaType + "/" + tmdbId + "/recommendations?language=en-US&page=1"
    transfer = CreateObject("roUrlTransfer")
    transfer.SetCertificatesFile("common:/certs/ca-bundle.crt")
    transfer.InitClientCertificates()
    transfer.AddHeader("Accept", "application/json")
    transfer.AddHeader("User-Agent", "Moonfin/1.0")

    ' v4 tokens go in the Authorization header, v3 keys go in the query string.
    if Left(apiKey, 3) = "eyJ"
        transfer.AddHeader("Authorization", "Bearer " + apiKey)
    else
        url = url + "&api_key=" + apiKey
    end if

    transfer.SetUrl(url)
    body = transfer.GetToString()
    if not isValidAndNotEmpty(body) then return []
    data = ParseJson(body)
    if not isChainValid(data, "results") then return []
    return data.results
end function

' Recommendations from the Seerr proxy, used when TMDB has no key or no result.
function fetchSeerrRecommendations(tmdbId as string, mediaType as string) as object
    req = APIRequest("/Moonfin/Seerr/Api/" + mediaType + "/" + tmdbId + "/recommendations", {})
    if not isValid(req) then return []
    data = getJson(req)
    if not isChainValid(data, "results") then return []
    return data.results
end function

' Online recommendations are gated on Seerr being available because tapping a
' card opens the Seerr detail screen. The row itself is sourced from TMDB first,
' falling back to Seerr recommendations.
function loadSinceYouWatchedOnline(seed as object) as object
    config = GetSeerrConfig()
    if not isValid(config) or config.enabled <> true then return []

    tmdbId = getSeedTmdbId(seed)
    if tmdbId = "" then return []

    mediaType = "movie"
    if seed.LookupCI("Type") = "Series" then mediaType = "tv"

    recommendations = fetchTmdbRecommendations(tmdbId, mediaType)
    if not isValidAndNotEmpty(recommendations) then recommendations = fetchSeerrRecommendations(tmdbId, mediaType)
    if not isValidAndNotEmpty(recommendations) then return []

    results = []
    count = 0
    for each res in recommendations
        if count >= 15 then exit for
        node = makeSeerrHomeItem(res, mediaType)
        if isValid(node)
            results.Push(node)
            count = count + 1
        end if
    end for
    return results
end function

' Builds one Since You Watched row seeded from the Nth recently watched item.
function loadSinceYouWatched() as object
    settings = m.global.session.user.settings

    rowIndex = 1
    if isValid(m.top.metadata) and isValid(m.top.metadata.rowIndex) then rowIndex = m.top.metadata.rowIndex

    sourceMode = getStringSetting(settings, "ui.home.sinceYouWatchedSource", "local")
    sourceItem = getStringSetting(settings, "ui.home.sinceYouWatchedSourceItem", "recentlyWatched")
    sourceType = getStringSetting(settings, "ui.home.sinceYouWatchedSourceType", "movies")
    includeWatched = getBoolSetting(settings, "ui.home.sinceYouWatchedIncludeWatched", false)

    seeds = loadSinceYouWatchedSeeds(sourceItem, sourceType)
    if seeds.Count() < rowIndex then return []
    seed = seeds[rowIndex - 1]
    if not isValid(seed) then return []

    ' Expose the seed name so the row can be titled after it.
    meta = m.top.metadata
    if not isValid(meta) then meta = {}
    meta.seedName = seed.LookupCI("Name")
    m.top.metadata = meta

    if LCase(sourceMode) = "online"
        onlineItems = loadSinceYouWatchedOnline(seed)
        if isValidAndNotEmpty(onlineItems) then return onlineItems
    end if

    return loadSinceYouWatchedLocal(seed, sourceType, includeWatched)
end function

function isFullyWatchedSeries(series as object, userId as string) as boolean
    userData = series.LookupCI("UserData")
    played = false
    unplayed = 0
    if isValid(userData)
        if userData.Played = true then played = true
        unplayedCount = userData.LookupCI("UnplayedItemCount")
        if isValid(unplayedCount) then unplayed = unplayedCount
    end if
    topUnplayed = series.LookupCI("UnplayedItemCount")
    if isValid(topUnplayed) then unplayed = topUnplayed
    if not played or unplayed > 0 then return false

    seriesId = series.LookupCI("Id")
    if not isValidAndNotEmpty(seriesId) then return true

    check = api.items.Get({
        UserId: userId,
        ParentId: seriesId,
        includeItemTypes: "Episode",
        recursive: true,
        filters: "IsUnplayed",
        limit: 1
    })
    if not isValid(check) then return true
    total = check.LookupCI("TotalRecordCount")
    if isValid(total) then return total = 0
    if isChainValid(check, "Items") then return check.Items.Count() = 0
    return true
end function

sub addRewatchShows(watchedItems as object, seriesLastPlayed as object, userId as string, seriesFields as string)
    epData = api.items.Get({
        UserId: userId,
        includeItemTypes: "Episode",
        filters: "IsPlayed",
        sortBy: "DatePlayed",
        sortOrder: "Descending",
        recursive: true,
        limit: 100,
        fields: "SeriesId,UserData",
        EnableTotalRecordCount: false
    })
    if not isChainValid(epData, "Items") then return

    seriesIds = []
    seen = {}
    for each ep in epData.Items
        sId = ep.LookupCI("SeriesId")
        if not isValidAndNotEmpty(sId) then continue for
        userData = ep.LookupCI("UserData")
        if isValid(userData)
            lastPlayed = userData.LookupCI("LastPlayedDate")
            if isValidAndNotEmpty(lastPlayed)
                existing = seriesLastPlayed[sId]
                if not isValid(existing) or lastPlayed > existing then seriesLastPlayed[sId] = lastPlayed
            end if
        end if
        if not seen.DoesExist(sId)
            seen[sId] = true
            seriesIds.Push(sId)
        end if
    end for
    if seriesIds.Count() = 0 then return

    seriesData = api.items.Get({
        UserId: userId,
        Ids: joinArray(seriesIds, ","),
        fields: seriesFields
    })
    if not isChainValid(seriesData, "Items") then return

    for each series in seriesData.Items
        if isFullyWatchedSeries(series, userId) then watchedItems.Push(series)
    end for
end sub

sub addRewatchCollections(watchedItems as object, collectionLastPlayed as object, userId as string)
    boxData = api.items.Get({
        UserId: userId,
        includeItemTypes: "BoxSet",
        recursive: true,
        limit: 50,
        fields: "ImageTags,UserData,ProductionYear",
        EnableTotalRecordCount: false
    })
    if not isChainValid(boxData, "Items") then return

    for each col in boxData.Items
        colId = col.LookupCI("Id")
        if not isValidAndNotEmpty(colId) then continue for

        childData = api.items.Get({
            UserId: userId,
            ParentId: colId,
            recursive: true,
            fields: "UserData"
        })
        if not isChainValid(childData, "Items") then continue for
        if childData.Items.Count() = 0 then continue for

        allPlayed = true
        maxLastPlayed = ""
        for each child in childData.Items
            childUserData = child.LookupCI("UserData")
            if not isValid(childUserData) or childUserData.Played <> true
                allPlayed = false
                exit for
            end if
            lastPlayed = childUserData.LookupCI("LastPlayedDate")
            if isValidAndNotEmpty(lastPlayed) and lastPlayed > maxLastPlayed then maxLastPlayed = lastPlayed
        end for

        if allPlayed
            watchedItems.Push(col)
            collectionLastPlayed[colId] = maxLastPlayed
        end if
    end for
end sub

function rewatchLastPlayed(item as object, seriesLastPlayed as object, collectionLastPlayed as object) as string
    itemId = item.LookupCI("Id")
    itemType = item.LookupCI("Type")
    if itemType = "BoxSet" and isValid(collectionLastPlayed[itemId]) then return collectionLastPlayed[itemId]
    if itemType = "Series" and isValid(seriesLastPlayed[itemId]) then return seriesLastPlayed[itemId]
    userData = item.LookupCI("UserData")
    if isValid(userData)
        lastPlayed = userData.LookupCI("LastPlayedDate")
        if isValidAndNotEmpty(lastPlayed) then return lastPlayed
    end if
    return ""
end function

sub shuffleRewatchItems(items as object)
    total = items.Count()
    for i = total - 1 to 1 step -1
        j = Rnd(i + 1) - 1
        temp = items[i]
        items[i] = items[j]
        items[j] = temp
    end for
end sub

sub sortRewatchItems(items as object, sortBy as string, seriesLastPlayed as object, collectionLastPlayed as object)
    if LCase(sortBy) = "random"
        shuffleRewatchItems(items)
        return
    end if

    total = items.Count()
    for i = 1 to total - 1
        current = items[i]
        currentLastPlayed = rewatchLastPlayed(current, seriesLastPlayed, collectionLastPlayed)
        j = i - 1
        while j >= 0 and rewatchLastPlayed(items[j], seriesLastPlayed, collectionLastPlayed) < currentLastPlayed
            items[j + 1] = items[j]
            j = j - 1
        end while
        items[j + 1] = current
    end for
end sub

' A series card should open its first episode when selected.
function resolveRewatchItem(item as object, userId as string) as object
    if item.LookupCI("Type") = "Series"
        seriesId = item.LookupCI("Id")
        if isValidAndNotEmpty(seriesId)
            epData = api.items.Get({
                UserId: userId,
                ParentId: seriesId,
                includeItemTypes: "Episode",
                recursive: true,
                sortBy: "SortName,ProductionYear",
                sortOrder: "Ascending",
                limit: 1,
                fields: "ImageTags,UserData,SeriesId,SeriesName,ParentIndexNumber,IndexNumber,SeriesPrimaryImageTag,ParentThumbItemId,ParentThumbImageTag,ParentBackdropImageTags,ParentBackdropItemId,BackdropImageTags"
            })
            if isChainValid(epData, "Items") and epData.Items.Count() > 0 then return epData.Items[0]
        end if
    end if
    return item
end function

' Gathers movies, series, and collections the user has fully watched.
function loadRewatch() as object
    settings = m.global.session.user.settings
    includeMovies = getBoolSetting(settings, "ui.home.rewatchIncludeMovies", true)
    includeShows = getBoolSetting(settings, "ui.home.rewatchIncludeShows", true)
    includeCollections = getBoolSetting(settings, "ui.home.rewatchIncludeCollections", true)
    sortBy = getStringSetting(settings, "ui.home.rewatchSortBy", "recentlyWatched")

    userId = m.global.session.user.id
    itemFields = "Genres,ProductionYear,PremiereDate,ImageTags,UserData,BackdropImageTags,SeriesPrimaryImageTag"

    watchedItems = []
    seriesLastPlayed = {}
    collectionLastPlayed = {}

    if includeMovies
        movieData = api.items.Get({
            UserId: userId,
            includeItemTypes: "Movie",
            filters: "IsPlayed",
            sortBy: "DatePlayed",
            sortOrder: "Descending",
            recursive: true,
            limit: 50,
            fields: itemFields,
            EnableTotalRecordCount: false
        })
        if isChainValid(movieData, "Items")
            for each movie in movieData.Items : watchedItems.Push(movie) : end for
        end if
    end if

    if includeShows then addRewatchShows(watchedItems, seriesLastPlayed, userId, itemFields)
    if includeCollections then addRewatchCollections(watchedItems, collectionLastPlayed, userId)

    if watchedItems.Count() = 0 then return []

    sortRewatchItems(watchedItems, sortBy, seriesLastPlayed, collectionLastPlayed)

    results = []
    count = 0
    for each item in watchedItems
        if count >= 15 then exit for
        resolved = resolveRewatchItem(item, userId)
        if isValid(resolved)
            results.Push(makeHomeItem(resolved))
            count = count + 1
        end if
    end for
    return results
end function

' Reads a synced hidden-items map from settings. Keys are item or series ids,
' values are the ISO time each was hidden.
function getHiddenItemsMap(settingKey as string) as object
    raw = m.global.session.user.settings[settingKey]
    if not isValid(raw) or raw = "" then return {}
    parsed = ParseJson(raw)
    if not isValid(parsed) or Type(parsed) <> "roAssociativeArray" then return {}
    return parsed
end function

' True when an item is hidden and has not been played since it was hidden.
' seriesOnly keys on the series id only, otherwise it falls back to the item id.
function isHiddenByMap(itemJson as object, hiddenMap as object, seriesOnly as boolean) as boolean
    if hiddenMap.Count() = 0 or not isValid(itemJson) then return false

    seriesId = itemJson.SeriesId
    key = invalid
    if isValid(seriesId) and seriesId <> ""
        key = seriesId
    else if not seriesOnly
        key = itemJson.Id
    end if
    if not isValid(key) or key = "" then return false

    hideTime = hiddenMap[key]
    if not isValid(hideTime) then return false

    userData = itemJson.UserData
    if isValid(userData)
        lastPlayed = userData.LastPlayedDate
        if isValid(lastPlayed) and lastPlayed <> "" and lastPlayed > hideTime then return false
    end if
    return true
end function

function filterHiddenResults(results as object, hiddenMap as object, seriesOnly as boolean) as object
    if hiddenMap.Count() = 0 then return results
    filtered = []
    for each entry in results
        if not isHiddenByMap(entry.json, hiddenMap, seriesOnly)
            filtered.push(entry)
        end if
    end for
    return filtered
end function

function loadContinueWatching() as object
    results = []

    params = {
        recursive: true,
        SortBy: "DatePlayed",
        SortOrder: "Descending",
        Filters: "IsResumable",
        MediaTypes: ItemType.VIDEO,
        excludeItemTypes: ItemType.BOOK,
        EnableTotalRecordCount: false
    }
    data = api.useritems.GetResumeItems(params)

    if not isChainValid(data, "Items")
        return results
    end if


    for each item in data.Items
        tmp = createSGNode("HomeData")
        tmp.Id = item.LookupCI("Id")
        tmp.name = item.LookupCI("name")
        tmp.type = item.LookupCI("Type")
        tmp.json = {
            Id: item.LookupCI("Id"),
            name: item.LookupCI("name"),
            Type: item.LookupCI("Type"),
            SeriesName: item.LookupCI("SeriesName"),
            SeriesId: item.LookupCI("SeriesId"),
            SeasonId: item.LookupCI("SeasonId"),
            ProductionYear: item.LookupCI("ProductionYear"),
            Status: item.LookupCI("Status"),
            EndDate: item.LookupCI("EndDate"),
            ParentIndexNumber: item.LookupCI("ParentIndexNumber"),
            IndexNumber: item.LookupCI("IndexNumber"),
            IndexNumberEnd: item.LookupCI("IndexNumberEnd"),
            OfficialRating: item.LookupCI("OfficialRating"),
            CollectionType: item.LookupCI("CollectionType"),
            ImageTags: item.LookupCI("ImageTags"),
            UserData: item.LookupCI("UserData"),
            ParentThumbItemId: item.LookupCI("ParentThumbItemId"),
            ParentThumbImageTag: item.LookupCI("ParentThumbImageTag"),
            ParentBackdropImageTags: item.LookupCI("ParentBackdropImageTags"),
            ParentBackdropItemId: item.LookupCI("ParentBackdropItemId"),
            SeriesPrimaryImageTag: item.LookupCI("SeriesPrimaryImageTag"),
            BackdropImageTags: item.LookupCI("BackdropImageTags")
        }
        results.push(tmp)
    end for

    return filterHiddenResults(results, getHiddenItemsMap("ui.home.hiddenContinueWatchingItems"), false)
end function

' Load merged Continue Watching and Next Up items
function loadMergedContinueWatching() as object
    results = []

    hiddenCW = getHiddenItemsMap("ui.home.hiddenContinueWatchingItems")
    hiddenNU = getHiddenItemsMap("ui.home.hiddenNextUpSeries")

    ' Load Continue Watching items
    resumeParams = {
        recursive: true,
        SortBy: "DatePlayed",
        SortOrder: "Descending",
        Filters: "IsResumable",
        MediaTypes: ItemType.VIDEO,
        excludeItemTypes: ItemType.BOOK,
        EnableTotalRecordCount: false
    }
    resumeData = api.useritems.GetResumeItems(resumeParams)

    ' Load Next Up items
    nextUpParams = {
        recursive: true,
        SortBy: "DatePlayed",
        SortOrder: "Descending",
        ImageTypeLimit: 1,
        UserId: m.global.session.user.id,
        EnableRewatching: m.global.session.user.settings["ui.details.enablerewatchingnextup"],
        DisableFirstEpisode: false,
        limit: 25,
        EnableTotalRecordCount: false
    }

    maxDaysInNextUp = m.global.session.user.settings["ui.details.maxdaysnextup"].ToInt()
    if isValid(maxDaysInNextUp)
        if maxDaysInNextUp > 0
            dateToday = CreateObject("roDateTime")
            dateCutoff = CreateObject("roDateTime")
            dateCutoff.FromSeconds(dateToday.AsSeconds() - (maxDaysInNextUp * 86400))
            nextUpParams.AddReplace("NextUpDateCutoff", dateCutoff.ToISOString())
        end if
    end if

    nextUpData = api.shows.GetNextUp(nextUpParams)

    ' Create a lookup map of resume item IDs for duplicate detection
    resumeItemIds = {}

    ' Add Continue Watching items first
    if isChainValid(resumeData, "Items")
        for each item in resumeData.Items
            if isHiddenByMap(item, hiddenCW, false) then continue for
            tmp = createSGNode("HomeData")
            tmp.Id = item.LookupCI("Id")
            tmp.name = item.LookupCI("name")
            tmp.type = item.LookupCI("Type")
            tmp.json = {
                Id: item.LookupCI("Id"),
                name: item.LookupCI("name"),
                Type: item.LookupCI("Type"),
                SeriesName: item.LookupCI("SeriesName"),
                SeriesId: item.LookupCI("SeriesId"),
                SeasonId: item.LookupCI("SeasonId"),
                ProductionYear: item.LookupCI("ProductionYear"),
                Status: item.LookupCI("Status"),
                EndDate: item.LookupCI("EndDate"),
                ParentIndexNumber: item.LookupCI("ParentIndexNumber"),
                IndexNumber: item.LookupCI("IndexNumber"),
                IndexNumberEnd: item.LookupCI("IndexNumberEnd"),
                OfficialRating: item.LookupCI("OfficialRating"),
                CollectionType: item.LookupCI("CollectionType"),
                ImageTags: item.LookupCI("ImageTags"),
                UserData: item.LookupCI("UserData"),
                ParentThumbItemId: item.LookupCI("ParentThumbItemId"),
                ParentThumbImageTag: item.LookupCI("ParentThumbImageTag"),
                ParentBackdropImageTags: item.LookupCI("ParentBackdropImageTags"),
                ParentBackdropItemId: item.LookupCI("ParentBackdropItemId"),
                SeriesPrimaryImageTag: item.LookupCI("SeriesPrimaryImageTag"),
                BackdropImageTags: item.LookupCI("BackdropImageTags")
            }
            results.push(tmp)
            ' Track this ID to avoid duplicates
            resumeItemIds[item.LookupCI("Id")] = true
        end for
    end if

    recentPlayedParams = {
        includeItemTypes: "Episode",
        filters: "IsPlayed",
        recursive: true,
        sortBy: "DatePlayed",
        sortOrder: "Descending",
        limit: 100,
        fields: "UserData,SeriesId",
        UserId: m.global.session.user.id
    }
    recentPlayedResponse = api.items.get(recentPlayedParams)

 ' Create a lookup map of series LastPlayedDate to populate nextup
    seriesLastPlayedMap = {}
    if isChainValid(recentPlayedResponse, "Items")
        for each item in recentPlayedResponse.Items
            sId = item.LookupCI("SeriesId")
            userData = item.LookupCI("UserData")
            if isValid(sId) and isValid(userData) and seriesLastPlayedMap[sId] = invalid
                seriesLastPlayedMap[sId] = userData["LastPlayedDate"]
            end if
        end for
    end if
    ' Add Next Up items that aren't already in Continue Watching
    if isChainValid(nextUpData, "Items")
        for each item in nextUpData.Items
            itemId = item.LookupCI("Id")
            seriesId = item.LookupCI("SeriesId")
            userData = item.LookupCI("UserData")
            if not isValid(userData) then userData = {}
            if userData["LastPlayedDate"] = invalid and isValid(seriesId)
                userData["LastPlayedDate"] = seriesLastPlayedMap[seriesId]
            end if
            if isHiddenByMap(item, hiddenNU, true) then continue for
            ' Only add if not already in resume items
            if not resumeItemIds.DoesExist(itemId)
                tmp = createSGNode("HomeData")
                tmp.json = {
                Id: itemId,
                name: item.LookupCI("name"),
                Type: item.LookupCI("Type"),
                SeriesName: item.LookupCI("SeriesName"),
                SeriesId: seriesId,
                SeasonId: item.LookupCI("SeasonId"),
                ProductionYear: item.LookupCI("ProductionYear"),
                Status: item.LookupCI("Status"),
                EndDate: item.LookupCI("EndDate"),
                ParentIndexNumber: item.LookupCI("ParentIndexNumber"),
                IndexNumber: item.LookupCI("IndexNumber"),
                IndexNumberEnd: item.LookupCI("IndexNumberEnd"),
                OfficialRating: item.LookupCI("OfficialRating"),
                CollectionType: item.LookupCI("CollectionType"),
                ImageTags: item.LookupCI("ImageTags"),
                UserData: userData,
                ParentThumbItemId: item.LookupCI("ParentThumbItemId"),
                ParentThumbImageTag: item.LookupCI("ParentThumbImageTag"),
                ParentBackdropImageTags: item.LookupCI("ParentBackdropImageTags"),
                ParentBackdropItemId: item.LookupCI("ParentBackdropItemId"),
                SeriesPrimaryImageTag: item.LookupCI("SeriesPrimaryImageTag"),
                BackdropImageTags: item.LookupCI("BackdropImageTags")
            }
                results.push(tmp)
            end if
        end for
    end if

    sortedResults = sortServerResultsByDate(results)
    return sortedResults
end function

' sortServerResultsByDate: Sorts multi-server results by a date field (descending)
'
' @param {array} results - Array of items from multiple servers
' @return {array} Sorted array
function sortServerResultsByDate(results as object) as object
    if not isValidAndNotEmpty(results) then return []

    ' Convert to array with sortable date values
    sortableItems = []
    for each item in results
        dateValue = invalid
        if isValid(item.json) and isValid(item.json.UserData)
            dateValue = item.json.UserData.LastPlayedDate
        end if
        sortableItems.push({
            item: item,
            sortDate: dateValue
        })
    end for

    ' Simple bubble sort (sufficient for small arrays)
    n = sortableItems.count()
    for i = 0 to n - 2
        for j = 0 to n - i - 2
            ' Compare dates (ISO strings compare correctly alphabetically for descending)
            date1 = sortableItems[j].sortDate
            date2 = sortableItems[j + 1].sortDate

            ' Handle invalid dates
            if not isValid(date1) then date1 = ""
            if not isValid(date2) then date2 = ""

            ' Swap if date1 < date2 (we want descending order)
            if date1 < date2
                temp = sortableItems[j]
                sortableItems[j] = sortableItems[j + 1]
                sortableItems[j + 1] = temp
            end if
        end for
    end for

    ' Extract sorted items
    sortedResults = []
    for each sortable in sortableItems
        sortedResults.push(sortable.item)
    end for

    return sortedResults
end function

