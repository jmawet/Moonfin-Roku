<?xml version="1.0" encoding="utf-8"?>
<component name="MediaBar" extends="Group">
    <children>
        <!-- Note: Backdrop is managed by parent Home component, not locally -->

        <!-- Logo shadow -->
        <Poster
            id="logoShadow"
            translation="[153, -12]"
            width="400"
            height="120"
            uri=""
            loadDisplayMode="scaleToFit"
            blendColor="0x000000"
            opacity="0.6"
            visible="false"
        />

        <!-- Logo image -->
        <Poster
            id="logoImage"
            translation="[150, -15]"
            width="400"
            height="120"
            uri=""
            loadDisplayMode="scaleToFit"
            visible="false"
        />

        <!-- Title text (if no logo available) -->
        <Label
            id="titleText"
            translation="[150, -15]"
            width="800"
            height="80"
            text=""
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF"
            wrap="true"
            numLines="2"
            visible="false"
        />

        <!-- Info overlay content with background box -->
        <Poster
            id="infoBackground"
            translation="[150, 580]"
            width="1620"
            uri="pkg:/images/icons/info-box-bg-white.9.png"
            loadDisplayMode="scaleToFit"
        />

        <LayoutGroup
            id="infoOverlayContent"
            translation="[170, 475]"
            layoutDirection="vert"
            itemSpacings="[8]">
            <!-- Metadata row (year, rating, runtime, stars) -->
            <LayoutGroup
                id="metadataRow"
                layoutDirection="horiz"
            >
                <Label id="yearLabel" font="font:SmallestBoldSystemFont" color="0xFFFFFFFF" text="" />
                <Label
                    id="separatorDot1"
                    font="font:SmallestSystemFont"
                    color="0xFFFFFFFF"
                    text="  •  "
                    visible="false"
                />
                <Group id="ratingGroup">
                    <Poster id="ratingBg" uri="pkg:/images/hd_focus.9.png" loadDisplayMode="scaleToFit" blendColor="#888888" opacity="1.0" visible="false" />
                    <Label id="ratingLabel" font="font:TinyBoldSystemFont" color="0xFFFFFFFF" text="" />
                </Group>
                <Label
                    id="separatorDot2"
                    font="font:SmallestSystemFont"
                    color="0xFFFFFFFF"
                    text="  •  "
                    visible="false"
                />
                <Label id="runtimeLabel" font="font:SmallestBoldSystemFont" color="0xFFFFFFFF" text="" />
                <Label
                    id="separatorDot3"
                    font="font:SmallestSystemFont"
                    color="0xFFFFFFFF"
                    text="•  "
                    visible="false"
                />
                <Label id="starLabel" font="font:SmallestBoldSystemFont" color="0xFFD700FF" text="★ " visible="false" />
                <Label id="communityRatingLabel" font="font:SmallestBoldSystemFont" color="0xFFFFFFFF" text="" />
                <Label
                    id="separatorDot4"
                    font="font:SmallestSystemFont"
                    color="0xFFFFFFFF"
                    text="  •  "
                    visible="false"
                />
                <Label id="genresLabel" font="font:SmallestBoldSystemFont" color="0xFFFFFFFF" text="" />
            </LayoutGroup>

            <RatingsRow
                id="ratingsRow"
                visible="false"
                labelFont="font:SmallBoldSystemFont"
                labelColor="#FFFFFF"
                ratingSpacing="16"
            />

            <!-- Overview (3 lines max) -->
            <Label
                id="overviewLabel"
                width="1580"
                font="font:SmallestSystemFont"
                color="0xFFFFFFFF"
                wrap="true"
                text=""
            />
        </LayoutGroup>        <!-- Left navigation arrow -->
        <Group
            id="leftArrow"
            translation="[40, 290]"
            visible="false"
        >
            <Poster
                id="leftArrowBg"
                width="64"
                height="64"
                uri="pkg:/images/icons/circle.png"
                loadDisplayMode="scaleToFit"
            />
            <Poster
                width="48"
                height="48"
                translation="[5, 8]"
                uri="pkg:/images/icons/chevron-left.png"
                loadDisplayMode="scaleToFit"
            />
        </Group>

        <!-- Right navigation arrow -->
        <Group
            id="rightArrow"
            translation="[1832, 290]"
            visible="false"
        >
            <Poster
                id="rightArrowBg"
                width="64"
                height="64"
                uri="pkg:/images/icons/circle.png"
                loadDisplayMode="scaleToFit"
            />
            <Poster
                width="48"
                height="48"
                translation="[10, 8]"
                uri="pkg:/images/icons/chevron-right.png"
                loadDisplayMode="scaleToFit"
            />
        </Group>

        <!-- Pause indicator (shows when paused) -->
        <Group
            id="pauseIndicator"
            translation="[920, 100]"
            visible="false"
        >
            <Rectangle
                width="80"
                height="40"
                color="0x000000"
                opacity="0.8"
            />
            <Label
                translation="[12, 8]"
                text="PAUSED"
                font="font:SmallBoldSystemFont"
                color="0xFFFFFFFF"
            />
        </Group>

        <Poster
            id="dotsBackground"
            translation="[860, 792]"
            width="215"
            height="35"
            uri="pkg:/images/dots.9.png"
            loadDisplayMode="scaleToFit"
        />
        <LayoutGroup
            id="indicatorDots"
            translation="[910, 670]"
            layoutDirection="horiz"
            vertAlignment="center"
            itemSpacings="[10]"
        />

        <!-- Gallery mode: MarkupGrid -->
        <Group id="galleryGroup" visible="false" translation="[29, -60]">
            <MarkupGrid
                id="galleryGrid"
                itemComponentName="GalleryItem"
                numColumns="5"
                numRows="1"
                itemSize="[1920, 1400]"
                itemSpacing="[5, 0]"
                drawFocusFeedback="false"
                columnWidths="[1400, 110, 110, 110, 110]"
            />
        </Group>

        <Animation id="contentFadeOut" duration="0.2" repeat="false" easeFunction="linear">
            <FloatFieldInterpolator id="contentFadeOutInterp" key="[0.0, 1.0]" keyValue="[1.0, 0.0]" fieldToInterp="infoOverlayContent.opacity" />
            <FloatFieldInterpolator id="logoFadeOutInterp" key="[0.0, 1.0]" keyValue="[1.0, 0.0]" fieldToInterp="logoImage.opacity" />
            <FloatFieldInterpolator id="logoShadowFadeOutInterp" key="[0.0, 1.0]" keyValue="[0.6, 0.0]" fieldToInterp="logoShadow.opacity" />
            <FloatFieldInterpolator id="titleFadeOutInterp" key="[0.0, 1.0]" keyValue="[1.0, 0.0]" fieldToInterp="titleText.opacity" />
            <FloatFieldInterpolator id="infoBgFadeOutInterp" key="[0.0, 1.0]" keyValue="[1.0, 0.0]" fieldToInterp="infoBackground.opacity" />
        </Animation>

        <Animation id="contentFadeIn" duration="0.3" repeat="false" easeFunction="inOutQuad">
            <FloatFieldInterpolator id="contentFadeInInterp" key="[0.0, 1.0]" keyValue="[0.0, 1.0]" fieldToInterp="infoOverlayContent.opacity" />
            <FloatFieldInterpolator id="logoFadeInInterp" key="[0.0, 1.0]" keyValue="[0.0, 1.0]" fieldToInterp="logoImage.opacity" />
            <FloatFieldInterpolator id="logoShadowFadeInInterp" key="[0.0, 1.0]" keyValue="[0.0, 0.6]" fieldToInterp="logoShadow.opacity" />
            <FloatFieldInterpolator id="titleFadeInInterp" key="[0.0, 1.0]" keyValue="[0.0, 1.0]" fieldToInterp="titleText.opacity" />
            <FloatFieldInterpolator id="infoBgFadeInInterp" key="[0.0, 1.0]" keyValue="[0.0, 1.0]" fieldToInterp="infoBackground.opacity" />
        </Animation>
    </children>

    <interface>
        <field id="itemSelected" type="node" alwaysNotify="true" />
        <field id="hasFocus" type="boolean" value="false" alwaysNotify="true" />
        <field id="currentBackdrop" type="string" alwaysNotify="true" />
    </interface>
</component>