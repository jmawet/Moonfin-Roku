<?xml version="1.0" encoding="utf-8"?>
<component name="ModernDetailButton" extends="Group">
    <children>
        <!-- Rounded pill background that grows to the right when focused -->
        <Poster id="btnBg" uri="pkg:/images/icons/circle.png" loadDisplayMode="scaleToFit"
            width="80" height="80" blendColor="#444444" opacity="0.6" />
        <Poster id="btnIcon" width="44" height="44" translation="[18, 18]" />
        <Label id="btnLabel" font="font:MediumBoldSystemFont" vertAlign="center" height="80"
            translation="[76, 0]" color="#101114" opacity="0" />
        <Animation id="expandAnim" duration="0.15" repeat="false" easeFunction="outQuad">
            <FloatFieldInterpolator id="bgWidthInterp" key="[0.0, 1.0]" keyValue="[80, 80]"
                fieldToInterp="btnBg.width" />
            <FloatFieldInterpolator id="labelOpacityInterp" key="[0.0, 1.0]" keyValue="[0, 0]"
                fieldToInterp="btnLabel.opacity" />
        </Animation>
    </children>
    <interface>
        <field id="iconUri" type="string" onChange="onIconChanged" />
        <field id="labelText" type="string" onChange="onLabelChanged" />
        <field id="buttonAction" type="string" />
        <field id="buttonIndex" type="integer" />
        <field id="highlighted" type="boolean" value="false" onChange="onHighlightChanged" />
    </interface>
</component>
