<?xml version="1.0" encoding="utf-8"?>
<component name="StudioCard" extends="Group">
    <children>
        <Rectangle id="cardBg" width="270" height="150" color="#FFFFFF" opacity="0.08" />
        <Poster id="logo" width="246" height="122" translation="[12, 14]"
            loadDisplayMode="scaleToFit" visible="false" />
        <Label id="name" width="250" height="150" translation="[10, 0]" horizAlign="center"
            vertAlign="center" wrap="true" maxLines="2" color="#EEEEEE" font="font:MediumBoldSystemFont" />
        <Poster id="focusRing" width="270" height="150" uri="pkg:/images/hd_focus.9.png" visible="false" />
    </children>
    <interface>
        <field id="itemContent" type="node" onChange="onContentChanged" />
        <field id="itemHasFocus" type="boolean" onChange="onFocusChanged" />
        <field id="drawFocusFeedback" type="boolean" value="false" />
    </interface>
</component>
